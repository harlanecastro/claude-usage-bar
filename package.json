{
  "name": "claude-usage-bar",
  "productName": "Claude Usage Bar",
  "version": "1.0.0",
  "description": "Your Claude weekly usage, right on the Windows taskbar and the macOS menu bar.",
  "author": "Harlane Castro",
  "license": "MIT",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "debug": "electron . --verbose",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "install-hooks": "node hooks/install.js",
    "test": "node scripts/run-electron-tests.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "12.11.1",
    "electron-store": "^8.2.0",
    "koffi": "^3.1.1"
  },
  "devDependencies": {
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.harlanecastro.claudeusagebar",
    "productName": "Claude Usage Bar",
    "files": [
      "src/**/*",
      "hooks/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/koffi/**",
      "**/node_modules/better-sqlite3/**"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "icon": "build/icon.png",
    "mac": {
      "category": "public.app-category.utilities",
      "minimumSystemVersion": "12.0",
      "darkModeSupport": true,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
